% -*- mode: erlang; -*- vim: set ft=erlang:
[
    {config, [
        #{
            files => ["src/**/*.erl"],
            ruleset => erl_files,
            rules => [
                % `if` is the clearest form for the numeric quadrant/split
                % comparisons that drive the tree traversal.
                {elvis_style, no_if_expression, disable},
                % The four area_query/* variants (list, deep-list, fold, any)
                % deliberately share the same quadrant-splitting traversal
                % skeleton; they are kept as separate inlined functions for
                % performance rather than collapsed into one higher-order pass.
                {elvis_style, dont_repeat_yourself, disable}
            ]
        },
        #{
            files => ["test/**/*.erl"],
            ruleset => erl_files,
            rules => [
                {elvis_style, no_debug_call, disable},
                {elvis_style, dont_repeat_yourself, disable}
            ]
        },
        #{
            files => ["rebar.config", "elvis.config"],
            ruleset => rebar_config
        }
    ]}
].
